{
  "Configuration": {
    // Server-level configuration.
    "Server": {
      // The minimum Microsoft.Extensions.Logging.LogLevel of a trace message that makes it through to the trace output.
      "TraceLevel": "Trace",
      // Whether verbose messages are generated or not.
      // ⚠️ Verbose messages may contain relatively sensitive information such as document locations, symbol names, and execution stack traces.
      // 🧩 Applications may configure the content of their verbose messages in more details.
      "Verbose": true,
      // The number of seconds a client will await a server connection before a connection is aborted.
      "ConnectTimeoutSeconds": 30,
      // The number of seconds between health check pings.
      // 👉 Determines how long the server process remains orphaned before initiating a shutdown when the client process that owns it is abruptly terminated.
      "HealthCheckIntervalSeconds": 5,
      // The maximum number of seconds the server will wait for an EXIT notification from the client after receiving a SHUTDOWN request.
      "ShutdownTimeoutSeconds": 10
    },
    // Workspace-level configuration.
    "Workspace": {
      // The default location of RDCore workspaces (source files) on disk.
      // 👉 This location is used as a root when the supplied WorkspaceUri is a relative URI.
      "DefaultLocation": "%USERAPPDATA%/RDCore/Workspaces",
      // The location of the workspace to work with if none is supplied. This folder should be created (by the client) as needed when it does not exist.
      "WorkspaceUri": "/Project1"
    },
    // Platform-level configuration.
    "Platform": {
      // The base Web URL of the platform.
      "BaseWebUrl": "https://rubberduckvba.ca",
      "ApiEndpoint": "/api",
      "Msal": {
        "TenantId": "6709cc6b-06d2-4773-a8d0-3c4aa50d54d8",
        "RedirectUrl": "/signin-rdcore",
        "ClientId": "TBD",
        "ApiScope": "api://TBD/api.access"
      },
      // The location of the RDCore LSP language server executable.
      // 👉 This setting is used by CLIENT applications to locate the RDCore LSP language server executable from its publish location.
      "ServerExecutable": "../RDCore.LanguageServer/RDCore.LanguageServer.exe",
      // The location of the RDCore LSP parsing server executable.
      // 👉 This setting is used by the language server to locate the RDCore LSP parser executable from its publish location.
      "ParserExecutable": "../RDCore.Parsing/RDCore.Parser.exe",

      "Extensions": {
        // The location RDCore plugins are discovered from. Plugins are identified by a folder containing a RDCore plugin manifest.
        // ⚠️ Modifying this setting for a plugin WILL break the RDCore platform.
        // If any extensions support plugins, they should be loaded from a './plugins' folder under their own plugins folder, 
        // such that the RDCore directory remains self-contained with its entire ecosystem.
        "Path": "../Extensions",
        // ✔️ RDCore will only load extensions that are in this list.
        "Allowed": [ "RDCore.Diagnostics" ],
        // 🚫 RDCore may block problematic extensions and prevent automatically loading them even when they are allowed.
        "Blocked": []
      },
      // Transport-level configuration. RDCore uses a NamedPipe transport layer by default.
      "Transport": {
        // The type of transport layer.
        // 👉 Only "NamedPipe" is supported for now, but "StdIO" and "Sockets" could technically be made to work as well.
        "Type": "NamedPipe",
        // Configuration settings for NamedPipe transport.
        "PipeConfig": {
          // The base name of the NamedPipe transport.
          // 🧩 This setting is required in both CLIENT and SERVER applications and MUST be different for each loaded SDK application.
          "PipeName": "RDCore.SDK.Server.Pipe",
          // The maximum number of pipe instances that can run concurrently.
          // ⚠️ Changing this setting without proper support for it could corrupt client/server communications.
          // Each server instance should append a random suffix to the pipe name to prevent this,
          // otherwise there needs to be a mechanism (mutex) to prevent multiple instances of the server application from being started.
          "MaximumInstances": 1
        },
        // Configuration settings for Socket transport. This section is not used in RDCore, but technically supported.
        "SocketConfig": {
          // The port to use for JSON-RPC.
          // 👉 Recommended range would be 49152-65535 for ephemeral sockets (dev), 1024-49151 for registered sockets (prod).
          "Port": 56789
        }
      }
    }
  }
}
