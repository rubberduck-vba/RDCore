{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../RDCore.SDK",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "/images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "RDCore.SDK",
      "_appTitle": "RDCore.SDK",
      "_appFooter": "©9562-7303 Québec inc. (2026)",
      "_appLogoPath": "/images/logo.png",
      "_appFaviconPath": "/images/favicon.ico",
      "_enableSearch": true,
      "pdf": false
    }
  }
}