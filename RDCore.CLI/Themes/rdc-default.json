{
  "theme": {
    "name": "rdc-default",
    "author": "9562-7303 Québec inc.",
    "version": "0.1",
    "config": {
      "shell": {
        "console-background": "0c0a50",
        "fg-default": "c0c0c0ff",
        "bg-highlight": "5f8dd3",
        "fg-highlight": "ffffff",
        "bg-dbg-breakpoint": "b51a17",
        "fg-dbg-breakpoint": "ffffff",
        "bg-dbg-current": "fdbf00",
        "fg-dbg-current": "000000"
      },
      "error": {
        "error-light": "e59a99",
        "error-accent1": "e95653",
        "error-accent2": "ff0301",
        "error-dark": "b51a17"
      },
      "success": {
        "success-light": "9be599",
        "success-accent1": "67d864",
        "success-accent2": "00fd17",
        "success-dark": "2ca329"
      },
      "information": {
        "info-light": "99c9e5",
        "info-accent1": "64aed8",
        "info-accent2": "00fefd",
        "info-dark": "2977a4"
      },
      "warning": {
        "warning-light": "e5cf99",
        "warning-accent1": "d8b064",
        "warning-accent2": "fdbf00",
        "warning-dark": "a37e29"
      },
      "trace": {
        "trace-light": "b9b9c3",
        "trace-accent1": "9898a4",
        "trace-accent2": "ffffff",
        "trace-dark": "62626f"
      }
    },
    "theme": {
      "fg-splash": "$(bg-highlight)",
      "source-listings": {
        "keyword": "3e61ff",
        "comment": "2ca329",
        "string-literal": "e59a99",
        "number-literal": "ffffff",
        "identifier": "99c9e5",
        "identifier-class": "2977a4",
        "identifier-const": "a37e29"
      },
      "message-parts": {
        "timestamp": {
          "error": "$(error-light)",
          "success": "$(success-dark)",
          "information": "$(information-dark)",
          "warning": "$(warning-dark)",
          "trace": "$(trace-dark)"
        },
        "title": {
          "error": "$(error-accent2)",
          "success": "$(success-accent2)",
          "information": "$(information-accent2)",
          "warning": "$(warning-accent2)",
          "trace": "$(trace-accent2)"
        },
        "body": {
          "error": "$(error-accent1)",
          "success": "$(success-accent1)",
          "information": "$(information-accent1)",
          "warning": "$(warning-accent1)",
          "trace": "$(trace-accent1)"
        },
        "verbose": {
          "error": "$(error-dark)",
          "success": "$(success-dark)",
          "information": "$(information-dark)",
          "warning": "$(warning-dark)",
          "trace": "$(trace-dark)"
        },
        "stack-trace": {
          "error": "$(error-dark)",
          "success": "$(success-dark)",
          "information": "$(information-dark)",
          "warning": "$(warning-dark)",
          "trace": "$(trace-dark)"
        },
        "metric": {
          "error": "$(error-accent2)",
          "success": "$(success-accent2)",
          "information": "$(information-accent2)",
          "warning": "$(warning-accent2)",
          "trace": "$(trace-accent2)"
        }
      }
    }
  }
}